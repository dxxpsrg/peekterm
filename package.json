{
  "name": "peekterm",
  "version": "2.0.0",
  "description": "맥OS 메뉴바 사이드패널 터미널 (Electron + React)",
  "main": "dist/main/index.js",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "rebuild": "electron-rebuild -f --only node-pty",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.peekterm.app",
    "productName": "peekterm",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "extendInfo": {
        "LSUIElement": true
      }
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "koffi": "^3.0.2",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^28.3.3",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
